PORT=3000
HOST=0.0.0.0

# Shared secret checked against the x-api-key header on every /lookup call.
API_KEY=change-me-to-a-long-random-string

CACHE_FILE_PATH=./data/cache.json

# Per-source scraping timeout before falling back to the next source.
SOURCE_TIMEOUT_MS=15000

# How long to keep a successful lookup cached.
POSITIVE_CACHE_TTL_DAYS=30

# How long to keep a "not found" result cached (short, in case it was a
# transient scraping failure rather than a genuine miss).
NEGATIVE_CACHE_TTL_HOURS=24
