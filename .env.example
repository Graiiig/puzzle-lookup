PORT=3000
HOST=0.0.0.0

# Shared secret checked against the x-api-key header on every /lookup call.
API_KEY=change-me-to-a-long-random-string

CACHE_FILE_PATH=./data/cache.json

# Overall budget for one source's whole lookup (navigation + extraction)
# before falling back to the next source.
SOURCE_TIMEOUT_MS=25000

# Budget for a single page navigation. Kept below SOURCE_TIMEOUT_MS so a
# lookup needing two navigations (search page + product page) still fits.
NAV_TIMEOUT_MS=10000

# How long to keep a successful lookup cached.
POSITIVE_CACHE_TTL_DAYS=30

# How long to keep a "not found" result cached when both sources genuinely
# determined the product doesn't exist there.
NEGATIVE_CACHE_TTL_HOURS=24

# How long to keep a "not found" result cached when it's actually a source
# error/timeout rather than a confirmed miss (short, so a permanent
# breakage doesn't get re-scraped on every single request, without locking
# in a false negative for the full negative TTL).
ERROR_CACHE_TTL_MINUTES=10

# Comma-separated list of origins allowed to call this API from a browser
# (CORS). Defaults to puzzle-tracker's GitHub Pages origin + local dev +
# the Capacitor Android WebView's default origin if unset.
# ALLOWED_ORIGINS=https://graiiig.github.io,http://localhost:5173,https://localhost
