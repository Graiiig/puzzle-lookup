{
  "name": "puzzle-lookup",
  "version": "1.0.0",
  "description": "Service HTTP de lookup EAN -> infos puzzle (marque, nom, nombre de pieces, image), pour l'app Mes Puzzles",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "inspect": "tsx scripts/inspect.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "fastify": "^5.10.0",
    "playwright": "1.56.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
